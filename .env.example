VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Soft invite gate on /login signup form. Visible in client bundle — friction not security.
# Set in Vercel env vars to rotate without code changes.
VITE_INVITE_CODE=Huginn_app2026!

# Meta (Facebook + Instagram) OAuth — public app id + redirect URI.
# App secret + token encryption key live as Supabase edge function secrets, not here.
VITE_META_APP_ID=
VITE_META_OAUTH_REDIRECT_URI=http://localhost:5173/auth/meta-callback
